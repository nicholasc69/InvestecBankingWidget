<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#11131C"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Header Section -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:text="INVESTEC BANK"
            android:textColor="#00E676"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_last_synced"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="Sync: --:--"
            android:textColor="#888888"
            android:textSize="9sp" />
    </RelativeLayout>

    <!-- Account & Balance Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#151824"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:id="@+id/widget_account_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No Accounts Synced"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1" />

        <TextView
            android:id="@+id/widget_account_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap to open app &amp; sync keys"
            android:textColor="#888888"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/widget_balance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="R --.--"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:text="RECENT POSTINGS:"
        android:textColor="#888888"
        android:textSize="9sp"
        android:textStyle="bold" />

    <!-- Transactions List Section -->
    <LinearLayout
        android:id="@+id/widget_tx_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Transaction Row 1 -->
        <RelativeLayout
            android:id="@+id/widget_tx_row_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_tx_desc_1"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Service Charge"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/widget_tx_amount_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="-R 535.00"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Transaction Row 2 -->
        <RelativeLayout
            android:id="@+id/widget_tx_row_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_tx_desc_2"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Service Charge"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/widget_tx_amount_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="-R 535.00"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Transaction Row 3 -->
        <RelativeLayout
            android:id="@+id/widget_tx_row_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_tx_desc_3"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Service Charge"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/widget_tx_amount_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="-R 535.00"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Transaction Row 4 -->
        <RelativeLayout
            android:id="@+id/widget_tx_row_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_tx_desc_4"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Service Charge"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/widget_tx_amount_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="-R 535.00"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Transaction Row 5 -->
        <RelativeLayout
            android:id="@+id/widget_tx_row_5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_tx_desc_5"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Service Charge"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/widget_tx_amount_5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="-R 535.00"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />
        </RelativeLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/widget_empty_txs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="8dp"
        android:text="No transaction details cached yet."
        android:textColor="#888888"
        android:textSize="10sp"
        android:visibility="visible" />

</LinearLayout>
