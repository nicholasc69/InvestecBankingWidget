<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Content container (shown when unlocked) -->
    <LinearLayout
        android:id="@+id/widget_content_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="visible">

        <!-- Header Section -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:text="INVESTEC PRIVATE BANKING"
                android:textColor="#001B3E"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_last_synced"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="Sync: --:--"
                android:textColor="#74777F"
                android:textSize="9sp" />
        </RelativeLayout>

        <!-- Account & Balance Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:background="@drawable/widget_account_background"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/widget_account_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:text="No Accounts Synced"
                android:textColor="#001B3E"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_account_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap to open app &amp; sync keys"
                android:textColor="#44474E"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/widget_balance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="R --.--"
                android:textColor="#001B3E"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:text="RECENT POSTINGS:"
            android:textColor="#74777F"
            android:textSize="9sp"
            android:textStyle="bold" />

        <!-- Transactions List Section -->
        <LinearLayout
            android:id="@+id/widget_tx_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Transaction Row 1 -->
            <RelativeLayout
                android:id="@+id/widget_tx_row_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="4dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/widget_tx_desc_1"
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Service Charge"
                    android:textColor="#1A1C1E"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/widget_tx_amount_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="-R 535.00"
                    android:textColor="#1A1C1E"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- Transaction Row 2 -->
            <RelativeLayout
                android:id="@+id/widget_tx_row_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="4dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/widget_tx_desc_2"
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Service Charge"
                    android:textColor="#1A1C1E"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/widget_tx_amount_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="-R 535.00"
                    android:textColor="#1A1C1E"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- Transaction Row 3 -->
            <RelativeLayout
                android:id="@+id/widget_tx_row_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="4dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/widget_tx_desc_3"
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Service Charge"
                    android:textColor="#1A1C1E"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/widget_tx_amount_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="-R 535.00"
                    android:textColor="#1A1C1E"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- Transaction Row 4 -->
            <RelativeLayout
                android:id="@+id/widget_tx_row_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="4dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/widget_tx_desc_4"
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Service Charge"
                    android:textColor="#1A1C1E"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/widget_tx_amount_4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="-R 535.00"
                    android:textColor="#1A1C1E"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- Transaction Row 5 -->
            <RelativeLayout
                android:id="@+id/widget_tx_row_5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="4dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/widget_tx_desc_5"
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Service Charge"
                    android:textColor="#1A1C1E"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/widget_tx_amount_5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="-R 535.00"
                    android:textColor="#1A1C1E"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </RelativeLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/widget_empty_txs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="8dp"
            android:text="No transaction details cached yet."
            android:textColor="#74777F"
            android:textSize="10sp"
            android:visibility="visible" />
    </LinearLayout>

    <!-- Locked container (shown when locked/blurred) -->
    <LinearLayout
        android:id="@+id/widget_locked_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="Locked"
            android:src="@drawable/ic_lock" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Tap to Unlock"
            android:textColor="#001B3E"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="Biometric Authentication Required"
            android:textColor="#74777F"
            android:textSize="10sp" />
    </LinearLayout>

</LinearLayout>
